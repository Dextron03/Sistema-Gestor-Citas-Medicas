## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This file is a combination of the VisualStudio.gitignore from
## https://github.com/github/gitignore and the JetBrains.gitignore
## from the same source.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (DotSettings)
*.csproj.DotSettings.user

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][In][32]/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if using tasks.vs.json
# !.vs/tasks.vs.json

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# Entity Framework Core of migrations
*.design.cs

# JetBrains Rider
.idea/
*.sln.iml
*.csproj.iml

# Visual Studio Code
.vscode/

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet Config to suppress settings hydration:
# !**/[Pp]ackages/repositories.config
# NuGet Store Cache
*.nuget.cache
# The results of NuGet restore
node_modules/

# Web / Frontend (Vite)
dist/
dist-ssr/
*.local
.env.development.local
.env.test.local
.env.production.local
.env.local

# OSS Index cache
.ossindex/

# Azure Functions local settings
local.settings.json

# Visual Studio 2017/2019/2022 auto-generated files
Generated\ Files/

# Windows image detail database
Thumbs.db

# Folder config file
Desktop.ini

# Others
publish/
*.publishsettings
*.db
*.log

# Sensitive information
# appsettings.Development.json # Optional: keep it if it doesn't contain secrets
# .env
